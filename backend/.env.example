# ============================================================
# The Kage Protocol — Backend Configuration
# ============================================================

# --- Required (app will NOT start without these) ---

# Admin credentials
ADMIN_USERNAME=Zor0ark
# Generate with: python scripts/hash_password.py <your_password>
ADMIN_PASSWORD_HASH=$2b$12$PASTE_YOUR_BCRYPT_HASH_HERE

# API key for public spawner (use a long random string)
KAGE_API_KEY=change-me

# Session cookie signing secret (use a long random string)
SESSION_SECRET=change-me-please

# --- Optional (sensible defaults) ---

# Session cookie settings
SESSION_COOKIE_NAME=kage_session
SESSION_MAX_AGE_SECONDS=3600

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:3000

# Database
DB_URL=sqlite:///./data/kage.db

# Public host returned by /spawn responses
PUBLIC_HOST=localhost

# Spawn rate limiting
SPAWN_RATE_LIMIT_COUNT=30
SPAWN_RATE_LIMIT_WINDOW_SECONDS=60

# Logging
LOG_LEVEL=INFO
JSON_LOGS=false

# Container isolation
CHALLENGE_NETWORK=kage-challenges
DEFAULT_CPU_LIMIT=0.5

# Cookie security (set true when behind TLS in production)
COOKIE_SECURE=false
